# Copy to .env and fill in as needed. Nothing here is required for the default
# fully-local setup (bge-m3 embeddings + Ollama Gemma + Chroma).

# --- LLM provider: "local" (Ollama) or "gemini" ---
LLM_PROVIDER=local
OLLAMA_MODEL=auto                 # "auto" picks an installed model; or set a tag like gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_KEEP_ALIVE=30m             # keep the model resident between queries (avoids cold reloads)
# OLLAMA_NUM_CTX=6144             # context window (unset = Ollama default; right-size to prompt+answer)
# OLLAMA_NUM_PREDICT=768          # cap generated tokens (unset = no cap)
GEMINI_MODEL=gemini-3-flash-preview
GOOGLE_API_KEY=
# Gemini hardening (fixes the 150s retry-storm + wrong "not addressed" fallback):
GEMINI_MAX_RETRIES=2              # fail fast instead of a long backoff storm
GEMINI_SAFETY=relaxed            # "relaxed" (BLOCK_NONE) avoids false refusals on scripture; or "default"
# GEMINI_THINKING_BUDGET=0       # cap thinking tokens (unset = model default; lower = faster first token)
# GEMINI_MAX_OUTPUT_TOKENS=768   # cap answer length (unset = model default)

# --- Embeddings: "local" (bge-m3), "gemini", or "voyage" ---
EMBED_PROVIDER=local
EMBED_MODEL=BAAI/bge-m3
VOYAGE_API_KEY=

# Device for local embedding + reranker models. Auto-detected (cuda > mps > cpu)
# when unset; set explicitly to force one, e.g. mps on Apple Silicon, or cpu.
# TORCH_DEVICE=mps

# --- Vector store ---
VECTOR_BACKEND=chroma
CHROMA_DIR=storage/chroma

# --- Retrieval ---
RERANKER_MODEL=BAAI/bge-reranker-base
RETRIEVE_K=20                     # candidates per arm before rerank (lower = faster rerank)
TOP_K=5
ENABLE_REWRITE=true               # CRAG rewrite retry; fires a blocking in-graph LLM call when on

# --- Docs ---
DOCS_DIR=Docs

# --- LangSmith tracing (optional) ---
# Get a key at https://smith.langchain.com -- no code changes needed, LangChain
# and LangGraph pick these up automatically once set.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=gitagpt
