# Copy to .env and fill in as needed. Nothing here is required for the default
# fully-local setup (bge-m3 embeddings + Ollama Gemma + Chroma).

# --- LLM provider: "local" (Ollama) or "gemini" ---
LLM_PROVIDER=local
OLLAMA_MODEL=auto                 # "auto" picks an installed model; or set a tag like gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434
GEMINI_MODEL=gemini-3-flash-preview
GOOGLE_API_KEY=

# --- Embeddings: "local" (bge-m3), "gemini", or "voyage" ---
EMBED_PROVIDER=local
EMBED_MODEL=BAAI/bge-m3
VOYAGE_API_KEY=

# --- Vector store ---
VECTOR_BACKEND=chroma
CHROMA_DIR=storage/chroma

# --- Retrieval ---
RERANKER_MODEL=BAAI/bge-reranker-base
RETRIEVE_K=20
TOP_K=5

# --- Docs ---
DOCS_DIR=Docs

# --- LangSmith tracing (optional) ---
# Get a key at https://smith.langchain.com -- no code changes needed, LangChain
# and LangGraph pick these up automatically once set.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=gitagpt
